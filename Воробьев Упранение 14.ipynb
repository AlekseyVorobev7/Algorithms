   "source": [
    "from collections import deque\n",
    "\n",
    "\n",
    "def is_consistent(n, edges):\n",
    "    \"\"\"\n",
    "        True  — если разбиение на виды A и B существует\n",
    "        False — если оценки противоречивы\n",
    "    \"\"\"\n",
    "    # Граф смежности: adj[v] = список (сосед, тип_ребра)\n",
    "    adj = [[] for _ in range(n)]\n",
    "    for i, j, t in edges:\n",
    "        adj[i].append((j, t))\n",
    "        adj[j].append((i, t))\n",
    "\n",
    "    color = [-1] * n  # -1 = не покрашен, 0 = вид A, 1 = вид B\n",
    "\n",
    "    for start in range(n):\n",
    "        if color[start] != -1:\n",
    "            continue  # вершина уже обработана\n",
    "\n",
    "        color[start] = 0\n",
    "        queue = deque([start])\n",
    "\n",
    "        while queue:\n",
    "            v = queue.popleft()\n",
    "            for nb, t in adj[v]:\n",
    "                # same → сосед того же цвета, diff → противоположного\n",
    "                expected = color[v] if t == 'same' else 1 - color[v]\n",
    "\n",
    "                if color[nb] == -1:\n",
    "                    color[nb] = expected\n",
    "                    queue.append(nb)\n",
    "                elif color[nb] != expected:\n",
    "                    return False  # противоречие!\n",
    "\n",
    "    return True\n",
    "\n",
    "\n",
    "# ---------------------------------------------------------------------------\n",
    "# Тесты\n",
    "# ---------------------------------------------------------------------------\n",
    "\n",
    "tests = [\n",
    "    # (описание, n, edges, ожидаемый результат)\n",
    "    (\n",
    "        \n",
    "        \"0,1 same; 2,3 same; 0,2 diff → {A,A} vs {B,B}\",\n",
    "        4,\n",
    "        [(0,1,'same'),(2,3,'same'),(0,2,'diff')],\n",
    "        True\n",
    "    ),\n",
    "    (\n",
    "        \"0,1 same И 0,1 diff одновременно\",\n",
    "        2,\n",
    "        [(0,1,'same'),(0,1,'diff')],\n",
    "        False\n",
    "    ),\n",
    "    (\n",
    "        \"Нечётный цикл diff: треугольник 0-1-2\",\n",
    "        3,\n",
    "        [(0,1,'diff'),(1,2,'diff'),(0,2,'diff')],\n",
    "        False\n",
    "    ),\n",
    "    (\n",
    "        \"Цепочка same: 0-1-2 одна группа, но 0,2 diff\",\n",
    "        3,\n",
    "        [(0,1,'same'),(1,2,'same'),(0,2,'diff')],\n",
    "        False\n",
    "    ),\n",
    "    (\n",
    "        \"Чётный цикл diff: квадрат 0-1-2-3 — двудольный\",\n",
    "        4,\n",
    "        [(0,1,'diff'),(1,2,'diff'),(2,3,'diff'),(3,0,'diff')],\n",
    "        True\n",
    "    ),\n",
    "    (\n",
    "        \"Нет рёбер — тривиально непротиворечиво\",\n",
    "        5,\n",
    "        [],\n",
    "        True\n",
    "    ),\n",
    "]\n",
    "\n",
    "print(f\"{'Тест':<45} {'Ожидание':<12} {'Результат':<12} {'OK?'}\")\n",
    "print(\"-\" * 80)\n",
    "for desc, n, edges, expected in tests:\n",
    "    result = is_consistent(n, edges)\n",
    "    ok = \"Ок\" if result == expected else \"Не верный ответ\"\n",
    "    print(f\"{desc:<45} {str(expected):<12} {str(result):<12} {ok}\")"
   ]
  }
